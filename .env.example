# Copy to .env and fill in your key.  The OpenAI client reads OPENAI_BASE_URL and
# OPENAI_API_KEY straight from the environment, so `OpenAI()` "just works".
#
# Both chat AND embeddings route through the class LiteLLM proxy — one base URL,
# one key. Get a key from your course Profile page (or run your own proxy).
OPENAI_BASE_URL=https://llm.nat-d.uk/v1
OPENAI_API_KEY=sk-replace-me

# Models the proxy exposes.
CHAT_MODEL=gemma-4-E4B-it
EMBED_MODEL=bge-m3

# Retrieval knobs (used from the RAG stage onward).
MIN_SCORE=0.40
TOP_K=4

# Optional: use Postgres + pgvector instead of SQLite (see docker-compose.yml).
#   docker compose up -d                 # Postgres + pgvector on host port 55432
#   uv sync --group pg                   # driver + pgvector + alembic
#   alembic upgrade head                 # create the schema via a migration
# Then uncomment this, re-ingest (`uv run python -m app.ingest corpus`), and run the app:
# DATABASE_URL=postgresql://rag:rag@localhost:55432/ragdemo
